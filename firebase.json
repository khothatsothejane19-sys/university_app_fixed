{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "firestore.rules",
      "SETUP_GUIDE.md"
    ],
    "rewrites": [
      { "source": "**", "destination": "/404.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
