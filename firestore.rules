rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Universities, news, timeline — public read, admin write only
    match /universities/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /news/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /timeline/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Notifications — public read, admin write only
    match /notifications/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // FCM tokens — any client can register their token, no public read
    match /fcm_tokens/{id} {
      allow read: if false;
      allow create: if true;
      allow update: if true;
    }

    // Analytics events — any client can write events, only admin can read
    match /analytics_events/{id} {
      allow read: if request.auth != null;
      allow create: if true;
    }
  }
}
